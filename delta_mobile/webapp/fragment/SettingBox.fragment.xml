<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox
        id="idSettingVBox"
        justifyContent="Center"
        class="sapUiTinyMarginTop"
    >
        <!-- Logs -->
        <Panel
            id="idSettingPanel"
            class="sapUiSmallMarginTop"
        >
            <headerToolbar>
                <OverflowToolbar id="idHeaderOptionToolbar">
                    <Title
                        id="idHeaderOptionTitle"
                        text="Header"
                    />
                </OverflowToolbar>
            </headerToolbar>
            <content>
                <HBox
                    id="idHeaderOptions"
                    height="30px"
                    justifyContent="Center"
                    class="sapUiTinyMarginTop sapUiMediumMarginBegin"
                >
                    <Button
                        id="idHeaderSettingButton"
                        text="Setting"
                        icon="sap-icon://customize"
                        press="onSetting"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />

                    <Button
                        id="idHeaderTooltipButton"
                        text="Tooltip"
                        icon="sap-icon://add"
                        press="onTooltip"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />
                    <Button
                        id="idHeaderSiteButton"
                        text="Website"
                        icon="sap-icon://chevron-phase"
                        press="onExternalWindow"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />

                    <Button
                        id="idHeaderActionButton"
                        text="History"
                        icon="sap-icon://contacts"
                        press="onBuyHistory"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />

                    <!-- Header Action  -->
                </HBox>
                <HBox
                    id="idSettingOptions"
                    height="30px"
                    justifyContent="Center"
                    class="sapUiTinyMarginTop sapUiMediumMarginBegin"
                >
                    <Button
                        id="idHeaderAddOnChartsButton"
                        icon="sap-icon://business-objects-experience"
                        press="onAddonCharts"
                        text="Line"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />

                    <Button
                        id="idHeaderRefreshButton"
                        text="Refresh"
                        icon="sap-icon://refresh"
                        press="onRefreshBuyInfo"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />

                    <Button
                        id="idHeaderDataLabelButton"
                        text="Label"
                        icon="sap-icon://horizontal-grip"
                        press="onDataLabel"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />
                    <Button
                        id="idHeaderOpenServer"
                        text="Server"
                        icon="sap-icon://database"
                        press="onOpenServer"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />
                </HBox>
            </content>
        </Panel>
        <!-- Refresh -->
        <Panel
            id="idBarOptionPanel"
            class="sapUiSmallMarginTop"
            height="150px"
        >
            <headerToolbar>
                <OverflowToolbar id="idBarOptionToolbar">
                    <Title
                        id="idBarOptionTitle"
                        text="Bar"
                    />
                </OverflowToolbar>
            </headerToolbar>
            <content>
                <HBox
                    id="idBarOption1Box"
                    height="30px"
                    justifyContent="Center"
                    class="sapUiTinyMarginTop sapUiMediumMarginBegin"
                >
                    <Button
                        id="idMarketBarButton"
                        text="Market"
                        icon="sap-icon://customer-and-supplier"
                        press="onOptionBar"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />
                    <Button
                        id="idOptionButton"
                        text="Option"
                        icon="sap-icon://multiselect-none"
                        press="onOptionBar"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />
                    <Button
                        id="idTrackButton"
                        text="Track"
                        icon="sap-icon://journey-change"
                        press="onOptionBar"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />
                    <Button
                        id="idBuyButton"
                        text="Buy"
                        icon="sap-icon://cart"
                        press="onOptionBar"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                    />
                </HBox>
                <HBox
                    id="idBarOption2Box"
                    height="30px"
                    justifyContent="Center"
                    class="sapUiTinyMarginTop sapUiMediumMarginBegin"
                >
                    <Button
                        id="idBookButton"
                        text="Book"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                        startsSection="true"
                        icon="sap-icon://course-book"
                        press="onOrderBookBar"
                    />
                    <Button
                        id="idHistoryBarButton"
                        text="History"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                        icon="sap-icon://alphabetical-order"
                        press="onTrnHistory"
                    />
                    <Button
                        id="idAlertMessageButton"
                        text="Message"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                        icon="sap-icon://email"
                        press="onBarMessage"
                    />
                    <Button
                        id="idAlertBarButton"
                        text="Alert"
                        width="95px"
                        class="sapUiMediumMarginEnd"
                        icon="sap-icon://bell"
                        press="onBarAlert"
                    />
                </HBox>
            </content>
        </Panel>
    </VBox>
    <MenuButton
        id="idHeaderActionMenuButton"
        useDefaultActionOnly="true"
        menuPosition="EndBottom"
        enabled="true"
        type="Transparent"
        visible="false"
    >
        <menu>
            <Menu id="idHeaderActionMenu">
                <MenuItem
                    id="idActionHeaderActionMenuItem"
                    text="Action"
                    icon="sap-icon://locate-me-2"
                >
                    <items>
                        <MenuItem
                            id="idLastPriceMenuItem"
                            key="lastprice"
                            text="Last Price"
                            icon="sap-icon://lead"
                            press="displayChartLtp"
                        />
                        <MenuItem
                            id="idBuyLineMenuItem"
                            key="buyline"
                            text="Buy Line"
                            icon="sap-icon://less"
                            press="displayBuyLine"
                        />
                        <MenuItem
                            id="idChartGuiMenuItem"
                            key="chartgui"
                            text="Chart Gui"
                            icon="sap-icon://chart-axis"
                            press="onDisplayStockTools"
                        />
                        <MenuItem
                            id="idRefreshMenuItem"
                            key="chartrefresh"
                            text="Refresh"
                            icon="sap-icon://refresh"
                            press="onChartRefresh"
                        />
                    </items>
                </MenuItem>
                <MenuItem
                    id="idVolumeTypeMenuItem"
                    text="Volume"
                    icon="sap-icon://measuring-point"
                >
                    <items>
                        <MenuItem
                            id="idVolumeTypeMarketMenuItem"
                            key="Market"
                            icon="sap-icon://customer-and-supplier"
                            text="Market"
                            press="onVolumeTypeMarket"
                        />
                        <MenuItem
                            id="idVolumeTypeOptionMenuItem"
                            key="Option"
                            icon="sap-icon://multiselect-none"
                            text="Option"
                            press="onVolumeTypeOption"
                        />
                    </items>
                </MenuItem>
                <MenuItem
                    id="idRightMenuItem"
                    text="Header"
                    startsSection="true"
                    icon="sap-icon://open-command-field"
                >
                    <items>
                        <MenuItem
                            id="idmHeaderTitleMenuItem"
                            key="display"
                            text="Title"
                            icon="sap-icon://display"
                            press="onHeaderTitle"
                        />
                        <MenuItem
                            id="idmHeaderMessageMenuItem"
                            key="message"
                            text="Message"
                            icon="sap-icon://email"
                            press="onHeaderMsg"
                        />
                        <MenuItem
                            id="idmHeaderZoomMenuItem"
                            text="Zoom"
                            icon="sap-icon://zoom-in"
                            press="onHeaderZoom"
                        />
                        <MenuItem
                            id="idmHeaderUpdateMenuItem"
                            text="Update"
                            icon="sap-icon://fob-watch"
                            press="onHeaderUpdate"
                        />
                        <MenuItem
                            id="idmHeaderAskGapMenuItem"
                            text="Ask Gap"
                            icon="sap-icon://decision"
                            press="onHeaderAskGap"
                        />
                    </items>
                </MenuItem>
            </Menu>
        </menu>
    </MenuButton>
</core:FragmentDefinition>

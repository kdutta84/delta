{
  "_version": "1.76.0",
  "sap.app": {
    "id": "ns.deltaapphost",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.19.0",
      "toolsId": "c6ef3167-9839-4090-abd2-df7c9aac4884"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.143.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ns.deltaapphost.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "ns.deltaapphost.view",
        "async": true,
        "viewPath": "ns.deltaapphost.view"
      },
      "routes": [
        {
          "name": "RouteMain",
          "pattern": ":?query:",
          "target": ["TargetMain"]
        },
        {
          "name": "Horizontal",
          "pattern": "Horizontal",
          "target": ["Horizontal"]
        },
        {
          "name": "Vertical",
          "pattern": "Vertical",
          "target": ["Vertical"]
        },
        {
          "name": "History",
          "pattern": "History",
          "target": ["History"]
        }
      ],
      "targets": {
        "TargetMain": {
          "id": "Main",
          "name": "Main"
        },
        "Horizontal": {
          "id": "Horizontal",
          "name": "Horizontal"
        },
        "Vertical": {
          "id": "Vertical",
          "name": "Vertical"
        },
        "History": {
          "id": "History",
          "name": "History"
        }
      }
    },
    "rootView": {
      "viewName": "ns.deltaapphost.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}

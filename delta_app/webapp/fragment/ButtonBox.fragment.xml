<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
>
    <!-- Action Buttons -->
    <HBox
        id="idActionButtonsHBox"
        alignItems="Start"
        alignContent="Start"
        width="500px"
        height="30px"
        class="sapUiTinyMarginBottom"
    >
        <Button
            id="idSettingButton"
            tooltip="Setting"
            icon="sap-icon://customize"
            press="onSetting"
            width="30px"
        />

        <Button
            id="idFullscreenButton"
            tooltip="Fullscreen"
            icon="sap-icon://full-screen"
            class="sapUiSmallMarginBegin"
            press="onFullscreen"
            width="30px"
        />
        <Button
            id="idTooltipButton"
            tooltip="Tooltip"
            icon="sap-icon://add"
            press="onTooltip"
            class="sapUiSmallMarginBegin"
            width="30px"
        />
        <Button
            id="idSiteButton"
            tooltip="Open Site"
            icon="sap-icon://chevron-phase"
            press="onExternalWindow"
            class="sapUiSmallMarginBegin"
            width="30px"
        />

        <Button
            id="idActionButton"
            tooltip="Records"
            icon="sap-icon://contacts"
            press="onBuyHistory"
            class="sapUiSmallMarginBegin"
            width="30px"
        />

        <Button
            id="idAddOnChartsButton"
            icon="sap-icon://business-objects-experience"
            press="onAddonCharts"
            class="sapUiSmallMarginBegin"
            width="30px"
        />

        <Button
            id="idRefreshButton"
            tooltip="Refresh"
            icon="sap-icon://refresh"
            press="onRefreshBuyInfo"
            class="sapUiSmallMarginBegin"
            width="30px"
        />

        <Button
            id="idDataLabelButton"
            tooltip="Data Label"
            icon="sap-icon://horizontal-grip"
            press="onDataLabel"
            class="sapUiSmallMarginBegin"
            width="30px"
        />
        <Button
            id="idOpenServer"
            tooltip="Server"
            icon="sap-icon://database"
            press="onOpenServer"
            class="sapUiSmallMarginBegin"
            width="30px"
            visible="true"
        />

        <Button
            id="idChartLayoutButton"
            tooltip="Chart Layout"
            icon="sap-icon://it-system"
            press="onChartLayout"
            class="sapUiSmallMarginBegin"
            width="30px"
            visible="true"
        />

        <!-- <Button
            id="idMarketWindow"
            tooltip="Market"
            icon="sap-icon://it-system"
            press="onMarketTab"
            class="sapUiSmallMarginBegin"
            width="30px"
            visible="true"
        /> -->

        <!-- Header Action  -->
        <MenuButton
            id="idHeaderActionMenuButton"
            useDefaultActionOnly="true"
            menuPosition="EndBottom"
            enabled="true"
            type="Transparent"
            visible="false"
        >
            <menu>
                <Menu id="idHeaderActionMenu">
                    <MenuItem
                        id="idActionHeaderActionMenuItem"
                        text="Action"
                        icon="sap-icon://locate-me-2"
                    >
                        <items>
                            <MenuItem
                                id="idLastPriceMenuItem"
                                key="lastprice"
                                text="Last Price"
                                icon="sap-icon://lead"
                                press="displayChartLtp"
                            />
                            <MenuItem
                                id="idBuyLineMenuItem"
                                key="buyline"
                                text="Buy Line"
                                icon="sap-icon://less"
                                press="displayBuyLine"
                            />
                            <MenuItem
                                id="idChartGuiMenuItem"
                                key="chartgui"
                                text="Chart Gui"
                                icon="sap-icon://chart-axis"
                                press="onDisplayStockTools"
                            />
                            <MenuItem
                                id="idRefreshMenuItem"
                                key="chartrefresh"
                                text="Refresh"
                                icon="sap-icon://refresh"
                                press="onChartRefresh"
                            />
                        </items>
                    </MenuItem>
                    <MenuItem
                        id="idThemeMenuItem"
                        text="Theme"
                        icon="sap-icon://palette"
                    >
                        <items>
                            <MenuItem
                                id="idLightMenuItem"
                                key="lighttheme"
                                icon="sap-icon://light-mode"
                                text="Light"
                                press="setLightTheme"
                            />
                            <MenuItem
                                id="idDarkMenuItem"
                                key="darktheme"
                                icon="sap-icon://dark-mode"
                                text="Dark"
                                press="setDarkTheme"
                            />
                        </items>
                    </MenuItem>
                    <MenuItem
                        id="idLayoutMenuItem"
                        text="Layout"
                        icon="sap-icon://vr-glasses"
                    >
                        <items>
                            <MenuItem
                                id="idHorizontalMenuItem"
                                key="horizontal"
                                icon="sap-icon://iphone-2"
                                text="Horizontal"
                                press="onHorizontalLayout"
                            />
                            <MenuItem
                                id="idVerticalMenuItem"
                                key="vertical"
                                icon="sap-icon://iphone"
                                text="Vertical"
                                press="onVerticalLayout"
                            />
                        </items>
                    </MenuItem>
                    <MenuItem
                        id="idVolumeTypeMenuItem"
                        text="Volume"
                        icon="sap-icon://measuring-point"
                    >
                        <items>
                            <MenuItem
                                id="idVolumeTypeMarketMenuItem"
                                key="Market"
                                icon="sap-icon://customer-and-supplier"
                                text="Market"
                                press="onVolumeTypeMarket"
                            />
                            <MenuItem
                                id="idVolumeTypeOptionMenuItem"
                                key="Option"
                                icon="sap-icon://multiselect-none"
                                text="Option"
                                press="onVolumeTypeOption"
                            />
                        </items>
                    </MenuItem>
                    <MenuItem
                        id="idRightMenuItem"
                        text="Right"
                        startsSection="true"
                        icon="sap-icon://open-command-field"
                    >
                        <items>
                            <MenuItem
                                id="idZoomMenuItem"
                                text="Zoom"
                                icon="sap-icon://zoom-in"
                                press="onHeaderRight"
                            />
                            <MenuItem
                                id="idUpdateMenuItem"
                                text="Update"
                                icon="sap-icon://fob-watch"
                                press="onHeaderRight"
                            />
                            <MenuItem
                                id="idAskGapMenuItem"
                                text="Ask Gap"
                                icon="sap-icon://decision"
                                press="onHeaderRight"
                            />
                            <!-- <MenuItem
                                    id="idHistoryMenuItem"
                                    text="History"
                                    icon="sap-icon://building"
                                    press="onHeaderRight"
                                /> -->
                        </items>
                    </MenuItem>
                    <MenuItem
                        id="idCenterMenuItem"
                        text="Center"
                        icon="sap-icon://media-pause"
                    >
                        <items>
                            <MenuItem
                                id="idMessageMenuItem"
                                key="message"
                                text="Message"
                                icon="sap-icon://email"
                                press="onHeaderCenter"
                            />
                            <MenuItem
                                id="idBacktestMenuItem"
                                key="backtest"
                                text="Backtest"
                                icon="sap-icon://measuring-point"
                                press="onHeaderCenter"
                            />
                        </items>
                    </MenuItem>
                    <MenuItem
                        id="idHeaderLeftMenuItem"
                        text="Left"
                        icon="sap-icon://close-command-field"
                    >
                        <items>
                            <MenuItem
                                id="idDisplayMenuItem"
                                key="display"
                                text="Display"
                                icon="sap-icon://display"
                                press="onHeaderLeft"
                            />
                            <MenuItem
                                id="idEditMenuItem"
                                key="edit"
                                text="Edit"
                                icon="sap-icon://edit"
                                press="onHeaderLeft"
                            />
                        </items>
                    </MenuItem>
                </Menu>
            </menu>
        </MenuButton>


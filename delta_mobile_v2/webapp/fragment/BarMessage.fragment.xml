<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table"
>
    <VBox
        id="idBarMessageOuterHBox"
        class="sapUiTinyMarginBegin"
    >
        <!-- <Toolbar
            id="idBarMessagesToolbar"
            width="500px"
            height="0.1px"
            class="sapUiTinyMarginBegin sapUiTinyMarginTop sapUiTinyMarginBottom"
        /> -->
        <HBox
            id="idBarMessageToolbar"
            justifyContent="Center"
            height="40px"
            class="sapUiTinyMarginTop"
        >
            <HBox
                id="idBarMessageToolbarHBox"
                justifyContent="Center"
                width="140px"
                class="sapUiTinyMarginBegin"
            >
                <SegmentedButton
                    id="idBarMessagePriority"
                    selectedKey="All"
                    class="sapUiSmallMarginBottom"
                >
                    <items>
                        <SegmentedButtonItem
                            id="idP1SegmentedButtonItem"
                            key="P1"
                            press="onBarMessagePriorityFilter"
                            icon="sap-icon://heading1"
                        />
                        <SegmentedButtonItem
                            id="idP2SegmentedButtonItem"
                            icon="sap-icon://heading2"
                            key="P2"
                            press="onBarMessagePriorityFilter"
                        />
                        <SegmentedButtonItem
                            id="idP3SegmentedButtonItem"
                            icon="sap-icon://heading3"
                            key="P3"
                            press="onBarMessagePriorityFilter"
                        />
                        <SegmentedButtonItem
                            id="idAllPriorityBarMessageSegmentedButtonItem"
                            icon="sap-icon://database"
                            key="All"
                            press="onBarMessagePriorityFilter"
                        />
                    </items>
                </SegmentedButton>
            </HBox>

            <HBox
                id="idBarMessageMiddleToolabrHBox"
                justifyContent="Center"
                width="130px"
            >
                <GenericTag
                    id="idBarMessageCountGenericTag"
                    text="Count : 0"
                    press="onClearMessages"
                />
            </HBox>

            <HBox
                id="idBarMessageRightToolabrHBox"
                justifyContent="Center"
                width="140px"
            >
                <SegmentedButton
                    id="idBarMessageType"
                    selectedKey="All"
                    class="sapUiSmallMarginBottom"
                >
                    <items>
                        <SegmentedButtonItem
                            id="idSuccessSegmentedButtonItem"
                            key="Success"
                            press="onBarMessageTypeFilter"
                            icon="sap-icon://message-success"
                        />
                        <SegmentedButtonItem
                            id="idErrorSegmentedButtonItem"
                            icon="sap-icon://message-error"
                            key="Error"
                            press="onBarMessageTypeFilter"
                        />
                        <SegmentedButtonItem
                            id="idInfoSegmentedButtonItem"
                            icon="sap-icon://hint"
                            key="Information"
                            press="onBarMessageTypeFilter"
                        />
                        <SegmentedButtonItem
                            id="idAllTypeBarMessageSegmentedButtonItem"
                            icon="sap-icon://database"
                            key="All"
                            press="onBarMessageTypeFilter"
                        />
                    </items>
                </SegmentedButton>
            </HBox>
        </HBox>

        <HBox
            id="barMsgTableBox"
            height="300px"
            width="500px"
            class="sapUiLargeMarginBegin"
        >
            <table:Table
                id="idBarMessageTable"
                rows="{MessageModel>/}"
                width="420px"
                ariaLabelledBy="title"
                selectionMode="None"
                alternateRowColors="true"
                rowMode="Auto"
                class="sapUiSmallMarginBegin"
            >
                <table:rowSettingsTemplate>
                    <table:RowSettings
                        id="idAlertRowSettings"
                        highlight="{MessageModel>type}"
                    />
                </table:rowSettingsTemplate>

                <table:columns>
                    <table:Column id="idBarMsgColumn">
                        <Label
                            id="idBarMsgLabel"
                            textAlign="Center"
                            text="Message"
                        />
                        <table:template>
                            <Text
                                id="idBarMsgText"
                                textAlign="Left"
                                text="{MessageModel>message}"
                            />
                        </table:template>
                    </table:Column>
                </table:columns>
            </table:Table>
        </HBox>
    </VBox>
</core:FragmentDefinition>

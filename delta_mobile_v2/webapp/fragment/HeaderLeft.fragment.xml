<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <HBox id="idHeaderLeftHBox">
        <HBox
            id="idChartTitleDisplayHBox"
            visible="{ path: 'ScreenModel>/mHeader', formatter: '.formatter.headerTitleDisplay' }"
        >
            <HBox
                id="idChartDisplaySymbolHBox"
                width="105px"
            >
                <core:Icon
                    id="idDisplayIcon"
                    src="sap-icon://bar-chart"
                    color="blue"
                />
                <Title
                    id="idNameChartDisplayTitle"
                    level="H3"
                    text="{TitleModel>/name}"
                    class="sapUiTinyMarginBegin"
                />
            </HBox>

            <HBox
                id="idDisplayCallHBox"
                width="100px"
            >
                <core:Icon
                    id="idDisplayCallStrikeIcon"
                    src="sap-icon://trend-up"
                    color="green"
                />
                <Title
                    id="idCallStrikeTitle"
                    level="H3"
                    text="{TitleModel>/callStrike}"
                    class="sapUiSmallMarginBegin"
                />
            </HBox>

            <HBox
                id="idChartDisplayPutHBox"
                width="100px"
            >
                <core:Icon
                    id="idChartDisplayIcon"
                    src="sap-icon://trend-down"
                    color="red"
                />
                <Title
                    id="idPutStrikeTitle"
                    level="H3"
                    text="{TitleModel>/putStrike}"
                    class="sapUiSmallMarginBegin"
                />
            </HBox>

            <HBox
                id="idChartEditSymbolHBox"
                width="60px"
            >
                <core:Icon
                    id="idChartEditSymbolIcon"
                    src="sap-icon://calendar"
                    color="blue"
                />
                <Title
                    id="idExpiryChartEditTitle"
                    level="H3"
                    text="{TitleModel>/expiry}"
                    class="sapUiSmallMarginBegin"
                />
            </HBox>
        </HBox>
        <!-- ///////////////////////////////////////// -->
        <!-- Chart Title Edit -->
        <!-- ///////////////////////////////////////// -->
        <HBox
            id="idChartEditHBox"
            visible="{ path: 'ScreenModel>/mHeader', formatter: '.formatter.headerTitleEdit' }"
        >
            <HBox
                id="idChartEditIconHBox"
                width="75px"
                visible="false"
            >
                <core:Icon
                    id="idChartEditIcon"
                    src="sap-icon://bar-chart"
                    color="blue"
                    class="sapUiTinyMarginTop"
                />
                <Title
                    id="idIndexChartEditTitle"
                    level="H3"
                    text="{TitleModel>/index}"
                    class="sapUiTinyMarginBegin"
                />
            </HBox>
            <HBox
                id="idChartEditCallHBox"
                width="145px"
            >
                <core:Icon
                    id="idChartEditCallIcon"
                    src="sap-icon://trend-up"
                    color="green"
                    class="sapUiTinyMarginTop"
                    press="onBothCallStrikes"
                />
                <StepInput
                    id="idCallStrikeChartEditStepInput"
                    min="0"
                    value="{TitleModel>/callStrike}"
                    step="{TitleModel>/window}"
                    change="onStrikeCe"
                    width="115px"
                    textAlign="Center"
                    class="sapUiTinyMarginBegin"
                />
            </HBox>

            <HBox
                id="idChartEditPutHBox"
                width="150px"
            >
                <core:Icon
                    id="idChartEditPutIcon"
                    src="sap-icon://trend-down"
                    color="red"
                    class="sapUiTinyMarginTop"
                    press="onBothPutStrikes"
                />
                <StepInput
                    id="idPutStrikeChartEditStepInput"
                    min="0"
                    value="{TitleModel>/putStrike}"
                    step="{TitleModel>/window}"
                    change="onStrikePe"
                    width="115px"
                    textAlign="Center"
                    class="sapUiTinyMarginBegin"
                />
            </HBox>

            <HBox
                id="idChartExpiryHBox"
                width="100px"
            >
                <core:Icon
                    id="idChartExpiryIcon"
                    src="sap-icon://calendar"
                    color="blue"
                    class="sapUiTinyMarginTop"
                    press="onBothOptionStrikes"
                />
                <MenuButton
                    id="idChartExpiryMenuButton"
                    text="{ path: 'ParaModel>/expiry/time', formatter: '.formatter.selectedExpiry' }"
                    enabled="true"
                    width="80px"
                >
                    <Menu
                        id="idChartExpiryMenu"
                        itemSelected="onExpiry"
                        items="{path: 'ExpiryModel>/'}"
                    >
                        <MenuItem
                            id="idTextChartExpiryMenuItem"
                            key="{ExpiryModel>key}"
                            text="{ExpiryModel>text}"
                        />
                    </Menu>
                </MenuButton>
            </HBox>
        </HBox>
    </HBox>
</core:FragmentDefinition>

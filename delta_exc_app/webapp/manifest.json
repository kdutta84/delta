{
  "_version": "1.81.0",
  "sap.app": {
    "id": "ns.deltaexcapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.2",
      "toolsId": "53d8c7af-cbd2-42c9-98d1-e18cff37c36e"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ns.deltaexcapp.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "ns.deltaexcapp.view",
        "async": true,
        "viewPath": "ns.deltaexcapp.view"
      },
      "routes": [
        {
          "name": "RouteMain",
          "pattern": ":?query:",
          "target": ["TargetMain"]
        },
        {
          "name": "Horizontal",
          "pattern": "Horizontal",
          "target": ["Horizontal"]
        },
        {
          "name": "Vertical",
          "pattern": "Vertical",
          "target": ["Vertical"]
        },
        {
          "name": "History",
          "pattern": "History",
          "target": ["History"]
        }
      ],
      "targets": {
        "TargetMain": {
          "id": "Main",
          "name": "Main"
        },
        "Horizontal": {
          "id": "Horizontal",
          "name": "Horizontal"
        },
        "Vertical": {
          "id": "Vertical",
          "name": "Vertical"
        },
        "History": {
          "id": "History",
          "name": "History"
        }
      }
    },
    "rootView": {
      "viewName": "ns.deltaexcapp.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}

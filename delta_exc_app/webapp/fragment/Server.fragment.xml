<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="idServerDialog"
        title="Server"
    >
        <content>
            <VBox id="idServerVBox">
                <!-- Time -->
                <HBox
                    id="idServerTimeHBox"
                    width="500px"
                    justifyContent="Center"
                    class="sapUiSmallMarginTop"
                >
                    <HBox
                        id="idServerStartedHBox"
                        justifyContent="Center"
                        width="400px"
                    >
                        <Label
                            id="idStartedLabel"
                            text="Started :"
                            design="Bold"
                            class="sapUiSmallMarginBegin sapUiTinyMarginTop"
                            width="80px"
                        />
                        <ObjectStatus
                            id="idServerStartedObjectStatus"
                            class="sapMObjectStatusLarge"
                            inverted="true"
                        />
                    </HBox>
                    <HBox
                        id="idServerOnTimeHBox"
                        justifyContent="Center"
                        width="250px"
                    >
                        <Label
                            id="idUpTimeLabel"
                            text="Up Time :"
                            design="Bold"
                            width="80px"
                            class="sapUiSmallMarginBegin sapUiTinyMarginTop"
                        />
                        <ObjectStatus
                            id="idObjectStatus"
                            class="sapMObjectStatusLarge"
                            inverted="true"
                        />
                    </HBox>
                </HBox>

                <!-- Logs -->
                <Panel
                    id="idLogsPanel"
                    width="auto"
                    class="sapUiResponsiveMargin"
                >
                    <headerToolbar>
                        <OverflowToolbar id="idLogsOverflowToolbar">
                            <Title
                                id="idLogsTitle"
                                text="Log"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <HBox
                            id="idLogsHBox"
                            width="500px"
                            justifyContent="Center"
                            class="sapUiTinyMarginTop"
                        >
                            <Button
                                id="idResetParaButton"
                                text="Reset Para"
                                icon="sap-icon://form"
                                width="130px"
                                press="onResetParaLog"
                                class="sapUiMediumMarginEnd"
                            />
                            <Button
                                id="idResetTrackButton"
                                text="Reset Track"
                                width="130px"
                                icon="sap-icon://compare"
                                press="onResetTrackLog"
                                class="sapUiMediumMarginEnd"
                            />
                            <Button
                                id="idResetBuyButton"
                                text="Reset Buy"
                                icon="sap-icon://cart"
                                press="onResetBuyLog"
                                width="130px"
                            />
                        </HBox>
                    </content>
                </Panel>
                <!-- Refresh -->
                <Panel
                    id="idRefreshPanel"
                    width="auto"
                    class="sapUiResponsiveMargin"
                >
                    <headerToolbar>
                        <OverflowToolbar id="idRefreshOverflowToolbar">
                            <Title
                                id="idRefreshTitle"
                                text="Restart"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <HBox
                            id="idRefreshHBox"
                            width="500px"
                            justifyContent="Center"
                            class="sapUiTinyMarginTop"
                        >
                            <Button
                                id="idWithLogButton"
                                text="Use Log"
                                width="130px"
                                press="onResetServerUsingLog"
                                icon="sap-icon://folder"
                                class="sapUiMediumMarginEnd"
                            />
                            <Button
                                id="idWithParaButton"
                                text="Use Para"
                                press="onResetServerUsingPara"
                                icon="sap-icon://multi-select"
                                width="130px"
                                class="sapUiMediumMarginEnd"
                            />
                            <Button
                                id="idWithDbButton"
                                text="Use Database"
                                icon="sap-icon://fridge"
                                press="onResetServerUsingDatabase"
                                width="130px"
                            />
                        </HBox>
                    </content>
                </Panel>

                <!-- Selection -->
                <Panel
                    id="idSelectionPanel"
                    width="auto"
                    class="sapUiResponsiveMargin"
                >
                    <headerToolbar>
                        <OverflowToolbar id="idSelectionOverflowToolbar">
                            <Title
                                id="idSelectionTitle"
                                text="Selection"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <HBox
                            id="idSelectionHBox"
                            width="500px"
                            justifyContent="Center"
                            class="sapUiTinyMarginTop"
                        >
                            <Button
                                id="idSelectBitcoin"
                                text="Bitcoin"
                                width="130px"
                                icon="sap-icon://bold-text"
                                type="{ path: 'ParaModel>/select/bitcoin', formatter: '.formatter.selectCoin' }"
                                class="sapUiMediumMarginEnd"
                                press="onSelectBitcoin"
                            />
                            <Button
                                id="idSelectEthereumButton"
                                text="Ethereum"
                                width="130px"
                                icon="sap-icon://collapse"
                                type="{ path: 'ParaModel>/select/Ethereun', formatter: '.formatter.selectCoin' }"
                                class="sapUiMediumMarginEnd"
                                press="onSelectEthereum"
                            />
                            <Button
                                id="idSelectSolana"
                                text="Solana"
                                width="130px"
                                icon="sap-icon://simple-payment"
                                type="{ path: 'ParaModel>/select/solana', formatter: '.formatter.selectCoin' }"
                                press="onSelectSolana"
                            />
                        </HBox>
                    </content>
                </Panel>

                <!-- Notification -->
                <Panel
                    id="idNotifyPanel"
                    width="auto"
                    class="sapUiResponsiveMargin"
                >
                    <headerToolbar>
                        <OverflowToolbar id="idNotifyOverflowToolbar">
                            <Title
                                id="idNotificationTitle"
                                text="Notification"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <HBox
                            id="idNotifyHBox"
                            width="500px"
                            justifyContent="Center"
                            class="sapUiTinyMarginTop"
                        >
                            <Button
                                id="idEmailButton"
                                text="Email"
                                icon="sap-icon://email"
                                width="130px"
                                type="{ path: 'ParaModel>/notify/email', formatter: '.formatter.notifyDevice' }"
                                class="sapUiMediumMarginEnd"
                                press="onEmailNotification"
                            />
                            <Button
                                id="idWhatsappButton"
                                text="Whatsapp"
                                width="130px"
                                type="{ path: 'ParaModel>/notify/whatsapp', formatter: '.formatter.notifyDevice' }"
                                icon="sap-icon://notification-2"
                                class="sapUiMediumMarginEnd"
                                press="onWhatsappNotification"
                            />
                            <Button
                                id="idFirebaseButton"
                                text="Firebase"
                                icon="sap-icon://legend"
                                width="130px"
                                type="{ path: 'ParaModel>/notify/firebase', formatter: '.formatter.notifyDevice' }"
                                press="onFirebaseNotification"
                            />
                        </HBox>
                    </content>
                </Panel>
            </VBox>
        </content>

        <buttons>
            <Button
                id="amountSubmit"
                text="Cancel"
                press="onAmountConfirm"
                type="Emphasized"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>

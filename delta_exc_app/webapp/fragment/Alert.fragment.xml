<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:table="sap.ui.table"
>
    <VBox id="idAlertOuterHBox">
        <Toolbar
            id="idvSepAlertToolbar"
            width="405px"
            height="0.1px"
            class="sapUiTinyMarginBegin sapUiTinyMarginTop sapUiTinyMarginBottom"
        />
        <HBox
            id="idAlert1Toolbar"
            justifyContent="Center"
            height="40px"
        >
            <HBox
                id="idAlertLeftToolbarHBox"
                justifyContent="Center"
                width="140px"
                class="sapUiTinyMarginBegin"
            >
                <SegmentedButton
                    id="idAlertType"
                    selectedKey="All"
                    class="sapUiSmallMarginBottom"
                >
                    <items>
                        <SegmentedButtonItem
                            id="idAlertSegmentedButtonItem"
                            key="Alert"
                            press="onAlertAlertFilter"
                            icon="sap-icon://bell"
                        />
                        <SegmentedButtonItem
                            id="idBuySegmentedButtonItem"
                            icon="sap-icon://cart"
                            key="Buy"
                            press="onAlertBuyFilter"
                        />
                        <SegmentedButtonItem
                            id="idSellSegmentedButtonItem"
                            icon="sap-icon://shipping-status"
                            key="Sell"
                            press="onAlertSellFilter"
                        />
                        <SegmentedButtonItem
                            id="idAllSegmentedButtonItem"
                            icon="sap-icon://database"
                            key="All"
                            press="onAlertAllFilter"
                        />
                    </items>
                </SegmentedButton>
            </HBox>

            <HBox
                id="idAlertMiddleToolabrHBox"
                justifyContent="Center"
                width="140px"
            >
                <GenericTag
                    id="idCountGenericTag"
                    text="Count : 0"
                />
            </HBox>

            <HBox
                id="idAlertRightToolabrHBox"
                justifyContent="Center"
                width="140px"
            >
                <Button
                    id="idClearAlertButton"
                    text="Clear"
                    press="onClearAlert"
                    icon="sap-icon://delete"
                />
            </HBox>
        </HBox>

        <HBox
            id="alertTableBox"
            height="435px"
        >
            <!-- Buy Table -->
            <table:Table
                id="idAlertTable"
                rows="{AlertModel>/}"
                width="400px"
                ariaLabelledBy="title"
                selectionMode="None"
                alternateRowColors="true"
                rowMode="Auto"
                class="sapUiSmallMarginBegin"
            >
                <table:columns>
                    <table:Column
                        id="idAlertTimeColumn"
                        width="80px"
                        hAlign="Center"
                    >
                        <Label
                            id="idAlertTimeLabel"
                            text="Time"
                        />
                        <table:template>
                            <Text
                                id="idTimeAlertText"
                                text="{AlertModel>time}"
                            />
                        </table:template>
                    </table:Column>
                    <table:Column
                        id="idAlertTriggerColumn"
                        width="85px"
                        hAlign="Center"
                    >
                        <Label
                            id="idAlertTriggerLabel"
                            text="Trigger"
                        />
                        <table:template>
                            <Text
                                id="idAlertTriggerText"
                                text="{AlertModel>trigger}"
                            />
                        </table:template>
                    </table:Column>
                    <table:Column
                        id="idAlertActionColumn"
                        width="70px"
                        hAlign="Center"
                    >
                        <Label
                            id="idAlertActionLabel"
                            text="Action"
                        />
                        <table:template>
                            <c:Icon
                                id="idAlertActionIcon"
                                src="{ path:'AlertModel>action', formatter: '.formatter.alertActionIcon' }"
                                color="{ path:'AlertModel>action', formatter: '.formatter.alertActionColor' }"
                            />
                        </table:template>
                    </table:Column>
                    <table:Column
                        id="idAlertIndexColumn"
                        width="70px"
                        hAlign="Center"
                    >
                        <Label
                            id="idAlertIndexLabel"
                            text="Index"
                        />
                        <table:template>
                            <Text
                                id="idAlertIndexText"
                                text="{AlertModel>index}"
                            />
                        </table:template>
                    </table:Column>
                    <table:Column
                        id="idAlertTypeColumn"
                        width="70px"
                        hAlign="Center"
                    >
                        <Label
                            id="idAlertTypeLabel"
                            text="Info"
                        />
                        <table:template>
                            <ObjectStatus
                                id="idAlertTypeObjectStatus"
                                text="{AlertModel>type}"
                                state="{ path: 'AlertModel>type', formatter: '.formatter.alertTypeStatus' }"
                                inverted="true"
                            />
                        </table:template>
                    </table:Column>
                </table:columns>
            </table:Table>
        </HBox>
    </VBox>
</c:FragmentDefinition>

<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:tnt="sap.tnt"
>
    <VBox
        id="idFilterVBox"
        class="sapUiTinyMarginBegin"
    >
        <HBox
            id="idFilterRow1HBox"
            height="50px"
        >
            <HBox
                id="idDateHBox"
                width="350px"
            >
                <Title
                    id="idDateLabel"
                    text="Date :"
                    class="sapUiTinyMarginTop"
                />
                <DateRangeSelection
                    id="idHistoryFilterDateRange"
                    change="onDateChange"
                    displayFormat="dd MMM"
                    width="170px"
                    class="sapUiTinyMarginBegin"
                    dateValue="{FilterModel>/from}"
                    secondDateValue="{FilterModel>/to}"
                />

                <tnt:InfoLabel
                    id="idDays"
                    text="{FilterModel>/days}"
                    colorScheme="7"
                    width="70px"
                    class="sapUiTinyMarginBegin sapUiTinyMarginTop"
                />
            </HBox>
            <HBox id="idFilterDaysHBox">
                <Button
                    id="idSubmitFilterButton"
                    text="Submit"
                    press="onSubmit"
                    icon="sap-icon://activate"
                    width="160px"
                />
            </HBox>
        </HBox>

        <HBox id="idFilterRow2HBox">
            <HBox
                id="idFilterCoinBox"
                height="50px"
                width="350px"
            >
                <SegmentedButton
                    id="idHistoryFilterCoin"
                    selectedKey="{FilterModel>/coin}"
                    selectionChange="processHistory"
                >
                    <items>
                        <SegmentedButtonItem
                            id="idHistoryFilterCoinBtcItem"
                            width="100px"
                            text="Bitcoin"
                            key="BTC"
                            icon="sap-icon://bold-text"
                        />
                        <SegmentedButtonItem
                            id="idHistoryFilterCoinEthItem"
                            width="110px"
                            text="Ethereum"
                            key="ETH"
                            icon="sap-icon://collapse"
                        />
                        <SegmentedButtonItem
                            id="idHistoryFilterCoinAllItem"
                            width="90px"
                            text="All"
                            key="All"
                            icon="sap-icon://lead"
                        />
                    </items>
                </SegmentedButton>
            </HBox>

            <HBox
                id="idFilterModeBox"
                height="50px"
            >
                <SegmentedButton
                    id="idHistoryFilterMode"
                    selectedKey="{FilterModel>/mode}"
                    selectionChange="processHistory"
                >
                    <items>
                        <SegmentedButtonItem
                            id="idHistoryFilterModeActiveItem"
                            width="90px"
                            text="Active"
                            key="Active"
                            icon="sap-icon://log"
                        />
                        <SegmentedButtonItem
                            id="idHistoryFilterModeTestItem"
                            width="70px"
                            text="Test"
                            key="Test"
                            icon="sap-icon://disconnected"
                        />
                    </items>
                </SegmentedButton>
            </HBox>
        </HBox>

        <HBox id="idFilterRow3HBox">
            <HBox
                id="idFilterZoneBox"
                height="50px"
                width="350px"
            >
                <SegmentedButton
                    id="idHistoryFilterZone"
                    selectedKey="{FilterModel>/zone}"
                    selectionChange="processHistory"
                >
                    <items>
                        <SegmentedButtonItem
                            id="idHistoryFilterZoneAsiaItem"
                            width="70px"
                            text="Asia"
                            key="Asia"
                            icon="sap-icon://translate"
                        />
                        <SegmentedButtonItem
                            id="idHistoryFilterZoneEuropeItem"
                            width="90px"
                            text="Europe"
                            key="Europe"
                            icon="sap-icon://choropleth-chart"
                        />
                        <SegmentedButtonItem
                            id="idHistoryFilterZoneUsaItem"
                            width="70px"
                            text="Usa"
                            key="Usa"
                            icon="sap-icon://official-service"
                        />
                        <SegmentedButtonItem
                            id="idHistoryFilterZoneAllItem"
                            width="70px"
                            icon="sap-icon://globe"
                            text="All"
                            key="All"
                        />
                    </items>
                </SegmentedButton>
            </HBox>

            <HBox id="idHsitoryFilterSubmitHBox">
                <SegmentedButton
                    id="idHistoryPnlMode"
                    selectedKey="{FilterModel>/pnl}"
                    selectionChange="processHistory"
                >
                    <items>
                        <SegmentedButtonItem
                            id="idHistoryFilterPnlProfitItem"
                            width="53px"
                            key="Profit"
                            icon="sap-icon://add"
                        />
                        <SegmentedButtonItem
                            id="idHistoryFilterPnlLossItem"
                            width="53px"
                            key="Loss"
                            icon="sap-icon://less"
                        />
                        <SegmentedButtonItem
                            id="idHistoryFilterPnlAllItem"
                            width="53px"
                            key="All"
                            icon="sap-icon://sum"
                        />
                    </items>
                </SegmentedButton>
            </HBox>
        </HBox>
    </VBox>
</c:FragmentDefinition>
